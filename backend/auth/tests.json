{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {
        "email": "testuser_reg@example.com",
        "password": "test123456",
        "full_name": "Тест Тестов"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "token": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "testuser_reg@example.com",
        "password": "test123456"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "token": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Request password reset",
      "method": "POST",
      "path": "/?action=request-reset",
      "body": {
        "email": "testuser_reg@example.com"
      },
      "expectedStatus": 200,
      "expectedBody": {
        "ok": true
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Confirm reset with wrong code",
      "method": "POST",
      "path": "/?action=confirm-reset",
      "body": {
        "email": "testuser_reg@example.com",
        "code": "000000",
        "new_password": "newpassword123"
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    }
  ]
}
